# Скопируйте в .env и заполните значения.

# === Токен Telegram бота ===
# Получить у @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# === Google Sheets: 4 CSV URL ===
# По умолчанию используются встроенные URL, можно не задавать.
# Если нужно использовать свои таблицы - опубликуйте каждую вкладку как CSV:
# Файл → Опубликовать в интернете → выбрать лист → CSV

# Вкладка 1: Logic_GDPR (Схема квалификации GDPR)
# CSV_URL_LOGIC_GDPR=https://docs.google.com/spreadsheets/d/e/.../pub?gid=2046117556&single=true&output=csv

# Вкладка 2: Content_Checklist (Чек-лист мер)
# CSV_URL_CONTENT_CHECKLIST=https://docs.google.com/spreadsheets/d/e/.../pub?gid=1062279979&single=true&output=csv

# Вкладка 3: System_Triggers (Профиль проекта)
# CSV_URL_SYSTEM_TRIGGERS=https://docs.google.com/spreadsheets/d/e/.../pub?gid=1004258855&single=true&output=csv

# Вкладка 4: Gemini_KB (База знаний для AI)
# CSV_URL_GEMINI_KB=https://docs.google.com/spreadsheets/d/e/.../pub?gid=1940152089&single=true&output=csv

# === Gemini API (опционально, пока не используется) ===
# GEMINI_API_KEY=your_gemini_api_key
